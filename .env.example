# =============================================================================
# Crossed Engine — Environment Template
# =============================================================================
# This file documents the runtime environment variables used by the application.
# Copy this to .env.local and adjust values to match your local setup.
# NOTE: This app is entirely local/offline — no API keys or secrets required.
# =============================================================================

# ── Ollama ───────────────────────────────────────────────────────────────────
# Address of your local Ollama instance.
OLLAMA_HOST=http://localhost:11434

# ── Flask Server ─────────────────────────────────────────────────────────────
# Host interface and port for the web UI.
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
